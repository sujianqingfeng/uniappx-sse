		color: #333333;
		margin-bottom: 10rpx;
	}
	
	.app-subtitle {
		font-size: 28rpx;
		color: #666666;
	}
	
	/* 内容区域 */
	.content {
		padding: 0 40rpx;
	}
	
	.card {
		background: #ffffff;
		border-radius: 16rpx;
		padding: 50rpx 40rpx;
		margin-bottom: 30rpx;
		box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
	}
	
	.card-title {
		font-size: 36rpx;
		font-weight: bold;
		color: #333333;
		text-align: center;
		margin-bottom: 20rpx;
	}
	
	.card-description {
		font-size: 28rpx;
		color: #666666;
		text-align: center;
		line-height: 1.6;
		margin-bottom: 50rpx;
	}
	
