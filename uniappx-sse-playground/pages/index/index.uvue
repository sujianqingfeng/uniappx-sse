  font-size: 14px;
  color: #8A8175;
  margin-bottom: 24px;
  letter-spacing: 1px;
}

.label {
  margin-bottom: 8px;
  font-size: 13px;
  color: #6B665C;
}

.tabs {
  flex-direction: row;
  flex-wrap: wrap;
  margin-bottom: 16px;
}

.tab {
  padding: 8px 16px;
  margin-right: 12px;
  margin-bottom: 12px;
  border-radius: 4px;
  border: 1px solid #EDE6DE;
  background-color: transparent;
}

.tab.active {
  border-color: #2D2A25;
  background-color: #2D2A25;
}

.tab-text {
  font-size: 14px;
  color: #6B665C;
}

.tab-text-active {
  color: #F5F2ED;
}

.input,
.textarea {
  box-sizing: border-box;
  padding: 12px 14px;
  font-size: 15px;
  color: #2D2A25;
  border: 1px solid #EDE6DE;
  border-radius: 4px;
  background-color: #F5F2ED;
  margin-bottom: 24px;
}

.textarea {
  min-height: 80px;
}

.actions {
  flex-direction: row;
  margin-bottom: 24px;
}

.btn {
  flex: 1;
  padding: 12px 0;
  border-radius: 4px;
  align-items: center;
  justify-content: center;
  border: 1px solid #EDE6DE;
}

.btn.primary {
  margin-right: 16px;
  border-color: #2D2A25;
  background-color: #2D2A25;
}

.btn.danger {
  background-color: transparent;
}

.primary-text {
  color: #F5F2ED;
  font-size: 15px;
}

.btn-text {
  color: #2D2A25;
  font-size: 15px;
}

.status-box {
  padding: 16px;
  border-radius: 4px;
  background-color: #EDE6DE;
}

.status-row {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding: 4px 0;
}

.divider {
  height: 1px;
  background-color: transparent;
  border-bottom: 1px solid #DFD8CE;
  margin: 12px 0;
}

.status-label {
  font-size: 14px;
  color: #6B665C;
}

.status-value {
  font-size: 14px;
  color: #2D2A25;
}

.log-card {
  padding-bottom: 12px;
}

.log-header {
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.log-list {
  flex-direction: column;
}

.log-item {
  padding: 16px 0;
  border-bottom: 1px solid #EDE6DE;
}

.log-meta {
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 8px;
}

.log-time {
  font-size: 12px;
  color: #8A8175;
}

.log-kind {
  font-size: 12px;
  color: #8A9980;
}

.log-text {
  font-size: 14px;
  color: #2D2A25;
  line-height: 1.5;
}

.empty {
  padding: 24px 0;
  text-align: center;
  font-size: 14px;
  color: #8A8175;
}
</style>
