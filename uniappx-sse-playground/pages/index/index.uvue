  margin-top: 12px;
  font-size: 15px;
  line-height: 24px;
  color: #6B665C;
}

.card {
  margin-bottom: 24px;
  padding: 24px;
  border-radius: 8px;
  background-color: #F5F2ED;
  border: 1px solid #EDE6DE;
}

