# Rename template configuration for SSE plugin
#
# Edit only the *_TO values you want to change.
# Leave empty to keep original.

############################
# Root project subdirectories
############################
ANDROID_ROOT_DIR_FROM="android-playground"
ANDROID_ROOT_DIR_TO="sse-android"

IOS_FRAMEWORK_DIR_FROM="ios-framework"
IOS_FRAMEWORK_DIR_TO="sse-ios-framework"

IOS_APP_DIR_FROM="ios-playground"
IOS_APP_DIR_TO="sse-ios-demo"

UNIAPP_DIR_FROM="uniapp-x-playground"
UNIAPP_DIR_TO="sse-uniapp-demo"

################################
# Android module and package ids
################################
# Library module directory name under ANDROID_ROOT_DIR
#ANDROID_LIBRARY_MODULE_DIR_FROM="android-lib"
#ANDROID_LIBRARY_MODULE_DIR_TO="sse-lib"

# App module directory name under ANDROID_ROOT_DIR (usually keep as app)
ANDROID_APP_MODULE_DIR_FROM="app"
ANDROID_APP_MODULE_DIR_TO=""

# Android package (namespace) for library and app
ANDROID_LIBRARY_PACKAGE_FROM="com.hens.android_lib"
ANDROID_LIBRARY_PACKAGE_TO="com.hens.sse.library"

ANDROID_APP_PACKAGE_FROM="com.hens.android_playground"
ANDROID_APP_PACKAGE_TO="com.hens.sse.demo"

################################
# iOS project/product identifiers
################################
# iOS Framework Xcode project name and product (Swift module / .framework name)
IOS_FRAMEWORK_PROJECT_NAME_FROM="ios-framework"
IOS_FRAMEWORK_PROJECT_NAME_TO="SSEFramework"

IOS_FRAMEWORK_PRODUCT_NAME_FROM="ios-framework"
IOS_FRAMEWORK_PRODUCT_NAME_TO="SSEFramework"

# iOS Framework bundle id
IOS_FRAMEWORK_BUNDLE_ID_FROM="com.hens.ios-framework"
IOS_FRAMEWORK_BUNDLE_ID_TO="com.hens.sse.framework"

# iOS App Xcode project name and bundle id
IOS_APP_PROJECT_NAME_FROM="ios-playground"
IOS_APP_PROJECT_NAME_TO="SSEDemo"

IOS_APP_BUNDLE_ID_FROM="com.hens.ios-playground"
IOS_APP_BUNDLE_ID_TO="com.hens.sse.demo"

########################
# UniApp X plugin module
########################
UTS_MODULE_ID_FROM="say-hi"
UTS_MODULE_ID_TO="sse-plugin"

UTS_MODULE_DISPLAY_NAME_FROM="say-hi"
UTS_MODULE_DISPLAY_NAME_TO="SSE Plugin"

UTS_MODULE_DESCRIPTION_FROM="say-hi"
UTS_MODULE_DESCRIPTION_TO="A Server-Sent Events plugin for UniApp by hens"

# Non-interactive confirmation. Set to "yes" to skip prompt.
# CONFIRM="yes"