# Rename template configuration (default values are current template names)
#
# Copy this file to rename.config.env and edit only the *_TO values you want to change.
# Leave empty to keep original.
# If your local template has already been changed, you can also adjust *_FROM.

############################
# Root project subdirectories
############################
ANDROID_ROOT_DIR_FROM="sse-android"
ANDROID_ROOT_DIR_TO=""

IOS_FRAMEWORK_DIR_FROM="SSEFramework"
IOS_FRAMEWORK_DIR_TO=""

IOS_APP_DIR_FROM="SSEDemo"
IOS_APP_DIR_TO=""

UNIAPP_DIR_FROM="sse-uniapp-demo"
UNIAPP_DIR_TO=""

################################
# Android module and package ids
################################
# Library module directory name under ANDROID_ROOT_DIR
#ANDROID_LIBRARY_MODULE_DIR_FROM="sse-lib"
#ANDROID_LIBRARY_MODULE_DIR_TO=""

# App module directory name under ANDROID_ROOT_DIR (usually keep as app)
ANDROID_APP_MODULE_DIR_FROM="app"
ANDROID_APP_MODULE_DIR_TO=""

# Android package (namespace) for library and app
ANDROID_LIBRARY_PACKAGE_FROM="com.hens.sse.library"
ANDROID_LIBRARY_PACKAGE_TO=""

ANDROID_APP_PACKAGE_FROM="com.hens.sse.demo"
ANDROID_APP_PACKAGE_TO=""

################################
# iOS project/product identifiers
################################
# iOS Framework Xcode project name and product (Swift module / .framework name)
IOS_FRAMEWORK_PROJECT_NAME_FROM="SSEFramework"
IOS_FRAMEWORK_PROJECT_NAME_TO=""

IOS_FRAMEWORK_PRODUCT_NAME_FROM="SSEFramework"
IOS_FRAMEWORK_PRODUCT_NAME_TO=""

# iOS Framework bundle id
IOS_FRAMEWORK_BUNDLE_ID_FROM="com.hens.SSEFramework"
IOS_FRAMEWORK_BUNDLE_ID_TO=""

# iOS App Xcode project name and bundle id
IOS_APP_PROJECT_NAME_FROM="SSEDemo"
IOS_APP_PROJECT_NAME_TO=""

IOS_APP_BUNDLE_ID_FROM="com.hens.SSEDemo"
IOS_APP_BUNDLE_ID_TO=""

########################
# UniApp X plugin module
########################
UTS_MODULE_ID_FROM="sse-plugin"
UTS_MODULE_ID_TO=""

UTS_MODULE_DISPLAY_NAME_FROM="sse-plugin"
UTS_MODULE_DISPLAY_NAME_TO=""

UTS_MODULE_DESCRIPTION_FROM="sse-plugin"
UTS_MODULE_DESCRIPTION_TO=""

# Non-interactive confirmation. Set to "yes" to skip prompt.
# CONFIRM="yes"